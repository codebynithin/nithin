{
  "name": "nithin",
  "version": "2.0.0",
  "private": true,
  "author": {
    "name": "Nithin Viswanathan",
    "email": "mails2nithin@gmail.com"
  },
  "homepage": "https://codebynithin.com",
  "scripts": {
    "predeploy": "npm run build && rm -rf docs && cp -r build docs",
    "deploy": "git add docs && git commit -m 'feat: deploy to docs' && git push",
    "lint": "eslint src vite.config.ts --ext .js,.jsx,.ts,.tsx",
    "start": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
    "lucide-react": "~0.539.0",
    "react": "~19.1.0",
    "react-dom": "~19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "~19.8.1",
    "@commitlint/config-angular": "~19.8.1",
    "@types/react": "~19.1.8",
    "@types/react-dom": "~19.1.6",
    "@typescript-eslint/eslint-plugin": "~8.59.2",
    "@typescript-eslint/parser": "~8.59.2",
    "@vitejs/plugin-react": "~6.0.1",
    "autoprefixer": "~10.4.20",
    "eslint": "~8.57.1",
    "eslint-plugin-react": "~7.37.5",
    "gh-pages": "~6.3.0",
    "husky": "~4.3.8",
    "lint-staged": "~11.0.0",
    "node": "~24.14.0",
    "postcss": "~8.5.6",
    "postcss-nesting": "~13.0.2",
    "postcss-scss": "~4.0.9",
    "prettier": "~2.3.0",
    "sass": "~1.93.2",
    "tailwindcss": "~3.4.17",
    "typescript": "~5.9.3",
    "vite": "~8.0.11"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "~1.0.0-rc.18"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/app/**/*.(tsx|ts|js|jsx)": [
      "eslint --fix"
    ],
    "src/**/*.(html|scss|json|tsx|ts|js|jsx)": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  }
}
